# =========================

# SERVER CONFIG

# =========================

PORT=5000
NODE_ENV=development

# =========================

# DATABASE

# =========================

MONGODB_URI=mongodb+srv://username@cluster.mongodb.net/travelmind

# =========================

# JWT AUTH

# =========================

JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRE=7d

# =========================

# GEMINI_API

# =========================

GEMINI_API_KEY=

# =========================

# CLIENT URL

# =========================

CLIENT_URL=http://localhost:5173

# =========================

# OPTIONAL EMAIL SERVICE

# =========================

EMAIL_USER=[example@gmail.com](mailto:example@gmail.com)
EMAIL_PASS=app_password

# =========================

# FRONTEND

# =========================

VITE_API_URL=http://localhost:5000/api
